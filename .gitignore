# ═══════════════════════════════════════════════════════
# ServeFlow .gitignore
# ═══════════════════════════════════════════════════════

# ── BUILD OUTPUTS ────────────────────────────────────────
target/
*.class
*.jar
*.war
*.ear

# Maven wrapper JAR (keep this)
!.mvn/wrapper/maven-wrapper.jar

# ── SECRETS — NEVER COMMIT THESE ─────────────────────────
# The application.properties contains real API keys locally.
# This ensures you never accidentally push them to GitHub.
src/main/resources/application-local.properties
application-local.properties

# ── LOGS ─────────────────────────────────────────────────
logs/
*.log
spring.log

# ── UPLOADS ──────────────────────────────────────────────
uploads/

# ── INTELLIJ IDEA ─────────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr

# ── VS CODE ───────────────────────────────────────────────
.vscode/

# ── ECLIPSE / STS ─────────────────────────────────────────
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# ── OS FILES ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── ENVIRONMENT ───────────────────────────────────────────
.env
*.env

# ── DOCKER ────────────────────────────────────────────────
# Uncomment when docker-compose is set up
# docker-data/
